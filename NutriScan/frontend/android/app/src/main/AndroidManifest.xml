    <application
        android:label="NutriScan"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:usesCleartextTraffic="true"> <!-- Apenas para desenvolvimento, remover em produção se não for necessário -->
        ...
    </application>
</manifest>